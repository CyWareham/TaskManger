// Silas Testing

// ** addTask Chatch2 Tests **

//Happy test
TEST_CASE("addTask, happy test") {
    vector<Task> tasks;
    istringstream input("Wash car\n12/25/2025\nHome\n2\n");
    auto* old = cin.rdbuf(input.rdbuf());
    addTask(tasks);
    cin.rdbuf(old);
    REQUIRE(tasks.size() == 1);
    REQUIRE(tasks[0].taskDescription == "Wash car");
    REQUIRE(tasks[0].taskDueDate == "12/25/2025");
    REQUIRE(tasks[0].taskTag == "Home");
    REQUIRE(tasks[0].priority == 2);
    REQUIRE_FALSE(tasks[0].isComplete);
}

//Sad test
TEST_CASE("addTask, sad test") {
    vector<Task> tasks;

    //Enters bad priority (99), then enters good priority (1)
    istringstream input("Homework\n01/01/2026\nSchool\n99\n1\n");
    auto* old = cin.rdbuf(input.rdbuf());
    addTask(tasks);
    cin.rdbuf(old);
    REQUIRE(tasks.size() == 1);
    REQUIRE(tasks[0].taskDescription == "Homework");
    REQUIRE(tasks[0].taskDueDate == "01/01/2026");
    REQUIRE(tasks[0].taskTag == "School");
    REQUIRE(tasks[0].priority == 1);
    REQUIRE_FALSE(tasks[0].isComplete);
}

