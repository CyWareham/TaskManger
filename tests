// loadTasks — happy path
TEST_CASE("loadTasks happy path -- loads tasks from file") {
    // Create test file
    ofstream file("Tasks.txt");
    file << "Task A;01/01/2025;Work;1;2\n";
    file << "Task B;02/01/2025;Home;0;3\n";
    file.close();

    vector<Task> tasks;

    loadTasks(tasks);

    REQUIRE(tasks.size() == 2);

    REQUIRE(tasks[0].taskDescription == "Task A");
    REQUIRE(tasks[0].isComplete == true);
    REQUIRE(tasks[0].priority == 2);

    REQUIRE(tasks[1].taskDescription == "Task B");
    REQUIRE(tasks[1].isComplete == false);
    REQUIRE(tasks[1].priority == 3);

    // Clean up
    remove("Tasks.txt");
}

