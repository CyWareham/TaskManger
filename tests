// ** searchTask Chatch2 Tests **

//Happy test
TEST_CASE("searchTask, happy test") {
    vector<Task> tasks;
    Task t1;
    t1.taskDescription = "Do homework";
    t1.taskDueDate = "10/10/2026";
    t1.taskTag = "School";
    t1.priority = 2;
    tasks.push_back(t1);
    Task t2;
    t2.taskDescription = "Wash car";
    t2.taskDueDate = "11/11/2026";
    t2.taskTag = "Personal";
    t2.priority = 3;
    tasks.push_back(t2);
    istringstream input("home\n");
    auto* cinOld = cin.rdbuf(input.rdbuf());
    ostringstream output;
    auto* coutOld = cout.rdbuf(output.rdbuf());
    searchTask(tasks);
    cin.rdbuf(cinOld);
    cout.rdbuf(coutOld);
    string out = output.str();
    REQUIRE(out.find("Do homework") != string::npos);
    REQUIRE(out.find("Wash car") == string::npos);
}

